# ==============================================================================
# PROJECT METADATA
# ==============================================================================
PROJECT_NAME="Employee Management System"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# ==============================================================================
# SECURITY (Required)
# Use 'openssl rand -hex 32' to generate a unique key for production
# ==============================================================================
SECRET_KEY="7d92f1b4a3c1e5d8f2b9a0c3d4e5f6a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days (60 * 24 * 8)

# ==============================================================================
# POSTGRES DATABASE
# Note: 'db' is the service name in docker-compose.yml
# ==============================================================================
POSTGRES_SERVER=db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=employee_db

# ==============================================================================
# CORS SETTINGS (JSON string or comma-separated)
# ==============================================================================
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

REDIS_HOST = redis
REDIS_PORT =  6379
